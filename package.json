{
  "name": "seoul-festival-chatbot-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "vue-tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "bundle:functions": "zip-it-and-ship-it netlify/functions .netlify/functions-build --archive-format=zip --manifest=.netlify/functions-build/manifest.json",
    "verify": "npm run test && npm run build && npm run bundle:functions",
    "check": "npm run verify"
  },
  "dependencies": {
    "@netlify/functions": "^5.3.0",
    "leaflet": "^1.9.4",
    "openai": "^6.16.0",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@netlify/zip-it-and-ship-it": "^15.2.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "typescript": "~5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.0.14",
    "vue-tsc": "^3.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
